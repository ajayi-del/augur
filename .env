MODE=paper
LIVE_MODE_CONFIRMED=false

# ValueChain — reads from ARIA kingdom state, no direct RPC needed
KINGDOM_STATE_PATH=/Users/dayodapper/kingdom/kingdom_state.json

# Polymarket — public API, no key needed for reading/paper bets
POLYMARKET_PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_MODE=paper
POLYMARKET_MIN_EDGE=0.08
POLYMARKET_MIN_LIQUIDITY=5000
POLYMARKET_MAX_BET_PCT=0.05
POLYMARKET_BANKROLL=100.0

# Jupiter / Solana — no key in paper mode
DRIFT_KEYPAIR_PATH=
DRIFT_GATEWAY_URL=http://localhost:8080
JUPITER_MODE=paper

# Bybit — no key in paper mode
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_MODE=paper

# Grok — disabled until key added (empty = skip entirely)
GROK_API_KEY=

# OpenRouter — disabled until key added
OPENROUTER_KEY=

# SoSoValue — disabled, rate-limited, replaced by ValueChain bridge
SOSOVALUE_API_KEY=

# Logging
LOG_LEVEL=INFO
AUGUR_LOG_PATH=/Users/dayodapper/CascadeProjects/AUGUR/logs/
